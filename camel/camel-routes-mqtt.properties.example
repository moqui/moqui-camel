# Copy selected properties to runtime/conf/camel-routes.properties to enable a broker-backed setup.

camel.sql.datasource=moquiDataSource

# Global MQTT settings
mqtt.broker.url=tcp://localhost:1883
mqtt.clientId=moqui-node-1

# Outbound route: Moqui service trigger -> SQL (DeviceRequestItem + Parameter) -> JSON -> MQTT v5
outbound.sql.query=SELECT dri.PARAMETER_ID as "parameterId", p.NUMERIC_VALUE as "numericValue", p.SYMBOLIC_VALUE as "symbolicValue" FROM DEVICE_REQUEST_ITEM dri JOIN PARAMETER p ON p.PARAMETER_ID = dri.PARAMETER_ID WHERE dri.REQUEST_NAME = :#requestName ORDER BY dri.SEQUENCE_NUM
outbound.publish.uri=paho-mqtt5:{{outbound.mqtt.topic}}?brokerUrl={{mqtt.broker.url}}&clientId={{mqtt.clientId}}_out
outbound.mqtt.topic=iot/parameters/out
outbound.afterPublish.enabled=true
outbound.afterPublish.uri=sql:UPDATE DEVICE_REQUEST SET LAST_UPDATED_STAMP = CURRENT_TIMESTAMP WHERE REQUEST_NAME = :#requestName?dataSource=#{{camel.sql.datasource}}

# Inbound route: MQTT v5 -> JSON -> INSERT ParameterLog -> optional Moqui service callback
# parameterLogId is generated by Camel if it is not present in the incoming JSON payload.
inbound.route.autoStartup=true
inbound.consume.uri=paho-mqtt5:{{inbound.mqtt.topic}}?brokerUrl={{mqtt.broker.url}}&clientId={{mqtt.clientId}}_in
inbound.mqtt.topic=iot/parameters/in
inbound.sql.uri=sql:INSERT INTO PARAMETER_LOG (PARAMETER_LOG_ID, PARAMETER_ID, OBSERVED_DATE, NUMERIC_VALUE) VALUES (:#parameterLogId, :#parameterId, CURRENT_TIMESTAMP, :#numericValue)?dataSource=#{{camel.sql.datasource}}
inbound.afterDb.enabled=true
inbound.afterDb.uri=moquiservice:{{inbound.moqui.callback.service}}
inbound.moqui.callback.service=moqui.camel.CamelConfigurationDrivenServices.defaultInboundCallback

# Recipe export route: SFTP file transfer to PLC/device
recipe.filename=recipe.txt
file.transfer.uri=sftp:{{sftp.user}}@{{sftp.host}}:{{sftp.port}}{{sftp.remote.dir}}
sftp.host=plc.example.com
sftp.port=22
sftp.user=admin
sftp.remote.dir=/recipe
